---
import SiteLayout from '../layouts/SiteLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import '../styles/gallery.css';
---
<SiteLayout>
  <main>
    <section id="tools" aria-label="Tools">
      <div class="tool-grid">
        <ToolCard
          href="/tools/flowclip/"
          thumb="FlowClip preview"
          thumbKind="flowclip"
          category="Creator diagrams"
          title="FlowClip"
          summary="Animated social diagrams from simple arrow text."
          description="Type a flow, pick a social ratio and theme, then export PNG, SVG, or WebM video."
          meta="Social-ready / Local-only / No canvas editor"
        />

      </div>
    </section>
    <span id="roadmap"></span>
  </main>
</SiteLayout>
